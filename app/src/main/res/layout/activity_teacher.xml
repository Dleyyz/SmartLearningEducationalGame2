<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient">

    <!-- Cinematic Background Layers -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_particle"
        android:alpha="0.1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="-50dp"
        android:layout_marginEnd="-50dp" />

    <!-- Top Section (Teacher Profile & Stats) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_section"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:paddingTop="48dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/avatar_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <View
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_particle"
                    android:alpha="0.3"/>
                <ImageView
                    android:id="@+id/ivTeacherAvatar"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:src="@drawable/teacher_photoicon"
                    android:padding="8dp"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tvTeacherLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Teacher Lvl 1"
                android:textColor="#FFEB3B"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/avatar_layout"
            app:layout_constraintTop_toTopOf="@id/avatar_layout">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STUDENT ACCURACY"
                android:textColor="#B3FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"/>
            
            <ProgressBar
                android:id="@+id/pbSuccessRate"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="4dp"
                android:progressDrawable="@drawable/bg_health_bar"
                android:progress="0"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="QUEST PROGRESS"
                android:textColor="#B3FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"/>
            
            <ProgressBar
                android:id="@+id/pbAssignments"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="4dp"
                android:progressDrawable="@drawable/bg_xp_bar"
                android:progress="0"/>

            <TextView
                android:id="@+id/tvClassesCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="16dp"
                android:text="0 Classes"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvWelcomeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="WELCOME BACK, TEACHER GUIDE"
            android:textColor="#B3FFFFFF"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/avatar_layout"/>

        <TextView
            android:id="@+id/tvTeacherWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="NAME"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvWelcomeLabel"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintTop_toBottomOf="@id/top_section">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card: Publish Quest -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#311B92"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PUBLISH NEW QUEST"
                        android:textColor="#FFEB3B"
                        android:textStyle="bold"
                        android:textSize="12sp"/>
                    
                    <EditText
                        android:id="@+id/etQuestTitle"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="Quest Title (e.g. MATH CHP 1)"
                        android:paddingHorizontal="16dp"
                        android:textColor="#333333"
                        android:textSize="15sp"/>

                    <!-- Rewards Section -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        
                        <EditText
                            android:id="@+id/etQuestXp"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_input_field"
                            android:hint="XP Reward"
                            android:inputType="number"
                            android:paddingHorizontal="16dp"
                            android:layout_marginEnd="4dp"/>

                        <EditText
                            android:id="@+id/etQuestGold"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_input_field"
                            android:hint="Gold Reward"
                            android:inputType="numberDecimal"
                            android:paddingHorizontal="16dp"
                            android:layout_marginStart="4dp"/>
                    </LinearLayout>

                    <!-- Difficulty Selection -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="SET DIFFICULTY"
                        android:textColor="#B3FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold"/>

                    <RadioGroup
                        android:id="@+id/rgDifficulty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="horizontal">
                        
                        <RadioButton
                            android:id="@+id/rbEasy"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="EASY"
                            android:textColor="#FFFFFF"
                            android:buttonTint="#4CAF50"/>

                        <RadioButton
                            android:id="@+id/rbNormal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="NORMAL"
                            android:textColor="#FFFFFF"
                            android:checked="true"
                            android:buttonTint="#FFEB3B"/>

                        <RadioButton
                            android:id="@+id/rbHard"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="HARD"
                            android:textColor="#FFFFFF"
                            android:buttonTint="#F44336"/>
                    </RadioGroup>
                    
                    <Button
                        android:id="@+id/btnSelectClasses"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_role_card"
                        android:text="Assign to Classes"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        app:backgroundTint="@null"/>
                    
                    <Button
                        android:id="@+id/btnAddQuest"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_button_quest"
                        android:text="PUBLISH QUEST"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        app:backgroundTint="@null"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Quest Management -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#311B92"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QUEST MANAGEMENT"
                        android:textColor="#FFEB3B"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginBottom="12dp"/>
                    
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvTeacherQuests"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_quest" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#1A237E"
        android:elevation="12dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">
        
        <LinearLayout android:id="@+id/navQuest" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_nav_quest_new" app:tint="#FFEB3B"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Quest" android:textColor="#FFEB3B" android:textSize="10sp" android:textStyle="bold"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navAvatar" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_camera" app:tint="#B3FFFFFF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile" android:textColor="#B3FFFFFF" android:textSize="10sp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navClasses" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_sort_by_size" app:tint="#B3FFFFFF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Classes" android:textColor="#B3FFFFFF" android:textSize="10sp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navDungeons" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_compass" app:tint="#B3FFFFFF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dungeons" android:textColor="#B3FFFFFF" android:textSize="10sp"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>