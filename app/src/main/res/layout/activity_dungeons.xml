<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dungeons_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FF">

    <!-- Premium RPG Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_section"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@drawable/bg_premium_gradient"
        android:paddingTop="48dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Avatar HUD -->
        <FrameLayout
            android:id="@+id/avatar_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <View
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:background="@drawable/bg_avatar_box"
                android:alpha="0.2"
                android:layout_gravity="center"/>
            <ImageView
                android:id="@+id/ivDungeonsAvatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/hero_player"
                android:padding="4dp"
                android:layout_gravity="center"/>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/stats_layout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/avatar_container"
            app:layout_constraintTop_toTopOf="@id/avatar_container">

            <TextView
                android:id="@+id/tvDungeonsWelcomeMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="DUNGEON EXPLORER"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:shadowColor="#80000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4"
                android:layout_marginBottom="8dp"/>

            <!-- Health Bar with Icon -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="❤️"
                    android:textSize="10sp"
                    android:layout_marginEnd="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Health"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- HP Bar -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:layout_marginBottom="8dp">
                <ProgressBar
                    android:id="@+id/pbDungeonsHP"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:progress="100"
                    android:progressDrawable="@drawable/bg_health_bar"/>
                <TextView
                    android:id="@+id/tvDungeonsHPValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="100 / 100"
                    android:textColor="#FFFFFF"
                    android:textSize="8sp"
                    android:textStyle="bold"/>
            </RelativeLayout>

            <!-- Experience Bar with Icon -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡"
                    android:textSize="10sp"
                    android:layout_marginEnd="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Experience"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- EXP Bar -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="20dp">
                <ProgressBar
                    android:id="@+id/pbDungeonsEXP"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:progress="40"
                    android:progressDrawable="@drawable/bg_xp_bar"/>
                <TextView
                    android:id="@+id/tvDungeonsEXPValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="40 / 100"
                    android:textColor="#FFFFFF"
                    android:textSize="8sp"
                    android:textStyle="bold"/>
            </RelativeLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvDungeonsLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_pill_toggle"
            android:backgroundTint="#4D000000"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="⭐ LVL 6"
            android:textColor="#FFEB3B"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/avatar_container" />

        <!-- Coins Display -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_pill_toggle"
            android:backgroundTint="#4D000000"
            android:paddingHorizontal="14dp"
            android:paddingVertical="5dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/stats_layout">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🪙"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"/>
            <TextView
                android:id="@+id/tvDungeonsCoins"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="40.00"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Content Section -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintTop_toBottomOf="@id/top_section"
        android:layout_marginTop="-20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Pill Toggle Tabs -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_pill_toggle"
                android:backgroundTint="#E0E4F5"
                android:padding="4dp">
                <TextView
                    android:id="@+id/btnGuildToggle"
                    android:layout_width="110dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="GUILD"
                    android:textColor="#757575"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/btnDungeonsActive"
                    android:layout_width="110dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_toggle_right_active"
                    android:backgroundTint="#311B92"
                    android:gravity="center"
                    android:text="DUNGEONS"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Progress Header -->
            <TextView
                android:id="@+id/tvDungeonProgressHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginStart="4dp"
                android:text="Available Dungeons (1/3 Unlocked)"
                android:textColor="#311B92"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"/>

            <!-- Dungeons List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDungeons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_dungeon" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        android:elevation="16dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">
        
        <LinearLayout android:id="@+id/navQuest" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_nav_quest_new" app:tint="#B3B3B3"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Quest" android:textColor="#B3B3B3" android:textSize="10sp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navAvatar" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_camera" app:tint="#B3B3B3"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile" android:textColor="#B3B3B3" android:textSize="10sp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navDungeons" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_compass" app:tint="#311B92"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dungeons" android:textColor="#311B92" android:textSize="10sp" android:textStyle="bold"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navClasses" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_sort_by_size" app:tint="#B3B3B3"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Classes" android:textColor="#B3B3B3" android:textSize="10sp"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>